{
  "name": "home-dashboard",
  "version": "7.1.0",
  "author": "Tom Hewitt",
  "scripts": {
    "build": "npm run build --ws",
    "build:backend": "npm run build --ws backend",
    "build:frontend": "npm run build --ws frontend",
    "deploy": "npm run deploy --ws",
    "frontend": "cd frontend && npm start",
    "lint-fix": "npm run lint-fix --ws",
    "prepare": "husky",
    "release": "npm run build && npm run deploy && iamtomhewitt-releaser"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@iamtomhewitt/releaser": "2.1.2",
    "date-fns": "4.1.0",
    "husky": "9.1.7",
    "serverless": "3.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}